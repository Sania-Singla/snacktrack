{
    "name": "snack-track",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "format": "prettier --write .",
        "client": "cd client && npm run dev",
        "server": "cd server && npm run dev",
        "dev": "concurrently \"npm run client\" \"npm run server\"",
        "build": "npm i && npm i --prefix client && npm i --prefix server"
    },
    "keywords": [],
    "author": "Sania",
    "license": "ISC",
    "description": "A web application to track your snacks",
    "devDependencies": {
        "concurrently": "^9.2.1",
        "prettier": "^3.6.2"
    }
}
