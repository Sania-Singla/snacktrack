{
  "version": 2,
  "name":"SnackTrack",
  "builds": [
      {
          "src": "src/server.js",
          "use": "@vercel/node"
      }
  ],
  "routes": [
      {
          "src": "/(.*)",
          "dest": "/",
          "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
      }
  ]
}